#!/usr/bin/env python3
"""
runit — read a README.md, figure out how to launch the tool it describes,
and run it. When there is more than one plausible way to launch, ask instead
of guessing.

Usage:
    runit                   # use README.md in the current directory
    runit path/to/dir       # use README.md in that directory
    runit path/to/FILE.md   # use that specific markdown file
    runit --list            # only show the candidates, don't run anything
    runit --yes             # run the single obvious candidate without confirming
    runit --setup           # run setup steps (pip install, …) first, then launch
    runit --bg              # run the launched process in the background; press
                            #   'q' (or Ctrl-C) to stop it
    runit --help            # show this help
"""

import os
import re
import sys
import time
import signal
import subprocess

# Single-keypress support for the "press q to stop" watcher. POSIX only; on
# platforms without these we simply fall back to a plain blocking wait.
try:
    import termios
    import tty
    import select
    _POSIX_TTY = True
except ImportError:
    _POSIX_TTY = False

# Section headings (lowercased) that tend to contain launch instructions,
# in rough order of how strongly they signal "this is how you run it".
RUN_SECTIONS = ["usage", "running", "run", "quick start", "quickstart",
                "getting started", "launch", "how to run", "example", "examples"]

# Substrings that suggest a code line is actually a launch command.
RUN_HINTS = [
    "./", "python ", "python3 ", "node ", "npm run", "npm start", "npx ",
    "yarn ", "pnpm ", "cargo run", "go run", "make ", "bash ", "sh ",
    "docker run", "docker compose", "docker-compose", "flask run",
    "uvicorn ", "gunicorn ", "rails ", "./gradlew", "mvn ", "java -jar",
]

# Lines that look like commands but are setup, not launch — skip these.
SETUP_HINTS = [
    "cp ", "chmod ", "export ", "cd ", "git clone", "mkdir ", "source ",
    "pip install", "npm install", "npm ci", "yarn install", "pnpm install",
    "apt ", "apt-get", "brew install", "poetry install", "bundle install",
    "cargo build", "go build", "make install", "make build",
]

# Fence languages whose contents we treat as shell commands. Anything with an
# explicit non-shell language (```json, ```python, ```yaml, …) is skipped so its
# contents can't be mistaken for launch commands. An empty tag (plain ```) is
# the common case for shell snippets, so it's allowed.
SHELL_LANGS = {
    "", "sh", "bash", "shell", "zsh", "console", "shellsession",
    "shell-session", "sh-session", "shellscript", "text", "plaintext",
}


class Block:
    """A fenced code block together with the heading it lives under."""
    def __init__(self, section, lang, lines):
        self.section = section          # lowercased nearest heading, or ""
        self.lang = lang                # lowercased fence language tag, or ""
        self.lines = lines              # raw lines inside the fence


def find_readme(target):
    """Resolve the argument to an actual markdown file path."""
    if os.path.isdir(target):
        for name in ("README.md", "readme.md", "Readme.md", "README.markdown"):
            candidate = os.path.join(target, name)
            if os.path.isfile(candidate):
                return candidate
        return None
    if os.path.isfile(target):
        return target
    return None


def parse_blocks(path):
    """Return a list of Block objects from the markdown file."""
    blocks = []
    section = ""
    in_fence = False
    fence_lines = []
    fence_lang = ""
    heading_re = re.compile(r"^\s{0,3}#{1,6}\s+(.*?)\s*#*\s*$")

    with open(path, "r", encoding="utf-8", errors="replace") as fh:
        for raw in fh:
            line = raw.rstrip("\n")
            stripped = line.strip()

            if stripped.startswith("```") or stripped.startswith("~~~"):
                if in_fence:
                    blocks.append(Block(section, fence_lang, fence_lines))
                    fence_lines = []
                    fence_lang = ""
                    in_fence = False
                else:
                    in_fence = True
                    marker = "```" if stripped.startswith("```") else "~~~"
                    info = stripped[len(marker):].strip()
                    # The first token of the info string is the language.
                    fence_lang = info.split()[0].lower() if info else ""
                continue

            if in_fence:
                fence_lines.append(line)
                continue

            m = heading_re.match(line)
            if m:
                section = m.group(1).strip().lower()

    return blocks


def clean_command(line):
    """Strip shell prompts and inline comments; return a runnable command or ''."""
    line = line.strip()
    if not line or line.startswith("#"):
        return ""
    # Drop a leading shell prompt like "$ " or "> ".
    line = re.sub(r"^[\$>]\s+", "", line)
    # Drop trailing inline comments (naive but fine for READMEs).
    if " #" in line:
        line = line.split(" #", 1)[0].strip()
    return line


def effective_segment(cmd):
    """The step that decides what a command does — the last '&&'-joined part.

    So `cd app && npm start` is judged by `npm start` (a launch), not by the
    leading `cd` (which would otherwise look like setup).
    """
    if "&&" in cmd:
        parts = [p.strip() for p in cmd.split("&&") if p.strip()]
        if parts:
            return parts[-1]
    return cmd


def is_setup(cmd):
    low = effective_segment(cmd).lower()
    return any(h in low for h in SETUP_HINTS)


def looks_like_launch(cmd):
    low = effective_segment(cmd).lower()
    return any(h in low for h in RUN_HINTS)


def score(cmd, section):
    """Higher score = more likely to be the intended launch command."""
    s = 0
    if section in RUN_SECTIONS:
        # Earlier sections in the list score higher.
        s += 10 - RUN_SECTIONS.index(section)
    if looks_like_launch(cmd):
        s += 5
    if effective_segment(cmd).startswith("./"):
        s += 3
    return s


def collect_candidates(blocks):
    """Return a de-duplicated, ranked list of (command, section, score)."""
    seen = set()
    candidates = []
    for block in blocks:
        if block.lang not in SHELL_LANGS:
            continue
        for raw in block.lines:
            cmd = clean_command(raw)
            if not cmd or is_setup(cmd):
                continue
            if not looks_like_launch(cmd) and block.section not in RUN_SECTIONS:
                continue
            if cmd in seen:
                continue
            seen.add(cmd)
            candidates.append((cmd, block.section, score(cmd, block.section)))
    candidates.sort(key=lambda c: c[2], reverse=True)
    return candidates


def collect_setup(blocks):
    """Return setup commands (pip install, npm install, …) in document order."""
    seen = set()
    setup = []
    for block in blocks:
        if block.lang not in SHELL_LANGS:
            continue
        for raw in block.lines:
            cmd = clean_command(raw)
            if not cmd or not is_setup(cmd):
                continue
            if cmd in seen:
                continue
            seen.add(cmd)
            setup.append(cmd)
    return setup


def ask_choice(candidates):
    """Show the candidates and let the user pick one (or quit)."""
    print("Multiple ways to launch were found — which one do you want to run?\n")
    for i, (cmd, section, _) in enumerate(candidates, 1):
        where = f"  (under “{section}”)" if section else ""
        print(f"  {i}) {cmd}{where}")
    print("  q) quit\n")

    while True:
        choice = input("Choice: ").strip().lower()
        if choice in ("q", "quit", ""):
            return None
        if choice.isdigit() and 1 <= int(choice) <= len(candidates):
            return candidates[int(choice) - 1][0]
        print("Please enter a number from the list, or 'q' to quit.")


def show_setup(setup_cmds):
    if setup_cmds:
        print("Setup steps that will run first:")
        for s in setup_cmds:
            print(f"  $ {s}")
        print()


def confirm(cmd, setup_cmds):
    show_setup(setup_cmds)
    reply = input(f"Run:  {cmd}\n[Y/n] ").strip().lower()
    return reply in ("", "y", "yes")


def run(cmd, cwd):
    print(f"\n$ {cmd}\n", flush=True)
    return subprocess.call(cmd, shell=True, cwd=cwd)


def _terminate(proc, grace=5.0):
    """Stop the child's whole process group: SIGTERM, then SIGKILL if it lingers."""
    if proc.poll() is not None:
        return
    for sig in (signal.SIGTERM, signal.SIGKILL):
        try:
            # The child leads its own process group (start_new_session=True),
            # so its PGID equals its PID — signal the group to catch children.
            os.killpg(proc.pid, sig)
        except (ProcessLookupError, PermissionError):
            try:
                proc.send_signal(sig)
            except ProcessLookupError:
                return
        deadline = grace / 10.0
        for _ in range(10):
            if proc.poll() is not None:
                return
            time.sleep(deadline)


def run_background(cmd, cwd):
    """Launch cmd detached from the terminal; stop it on 'q' or Ctrl-C."""
    print(f"\n$ {cmd}\n", flush=True)
    watchable = _POSIX_TTY and sys.stdin.isatty()

    # Switch the terminal to cbreak mode *before* launching, so a 'q' pressed
    # early is delivered a keystroke at a time (not line-buffered) and isn't
    # echoed to the screen.
    old_attrs = None
    if watchable:
        old_attrs = termios.tcgetattr(sys.stdin)
        tty.setcbreak(sys.stdin.fileno())
        print("(running in the background — press 'q' to stop)\n", flush=True)

    # Give the child its own session so we can signal the whole group, and cut
    # it off from our stdin so keypresses reach runit's watcher, not the child.
    proc = subprocess.Popen(
        cmd, shell=True, cwd=cwd,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )

    stopped_by_user = False
    try:
        if not watchable:
            # No interactive terminal to read 'q' from — just wait it out.
            proc.wait()
        else:
            while proc.poll() is None:
                ready, _, _ = select.select([sys.stdin], [], [], 0.2)
                if ready and sys.stdin.read(1).lower() == "q":
                    print("\nStopping…", flush=True)
                    _terminate(proc)
                    stopped_by_user = True
                    break
    except KeyboardInterrupt:
        print("\nStopping…", flush=True)
        _terminate(proc)
        stopped_by_user = True
    finally:
        if old_attrs is not None:
            termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_attrs)

    # A deliberate stop is a success; otherwise report the child's own code.
    if stopped_by_user:
        return 0
    return proc.returncode or 0


def main(argv):
    args = [a for a in argv if not a.startswith("-")]
    flags = {a for a in argv if a.startswith("-")}
    list_only = "--list" in flags
    auto_yes = "--yes" in flags or "-y" in flags
    do_setup = "--setup" in flags
    background = "--bg" in flags or "--background" in flags

    if "--help" in flags or "-h" in flags:
        print(__doc__.strip())
        return 0

    target = args[0] if args else "."
    readme = find_readme(target)
    if not readme:
        print(f"No README.md found for '{target}'.", file=sys.stderr)
        return 1

    workdir = os.path.dirname(os.path.abspath(readme)) or "."
    print(f"Reading {readme}\n")

    blocks = parse_blocks(readme)
    candidates = collect_candidates(blocks)
    if not candidates:
        print("Couldn't find any launch command in the README.", file=sys.stderr)
        return 1

    if list_only:
        for cmd, section, sc in candidates:
            where = f"  (under “{section}”)" if section else ""
            print(f"  [{sc:>2}] {cmd}{where}")
        return 0

    # Decide whether the launch method is unambiguous.
    top = candidates[0]
    tied = [c for c in candidates if c[2] == top[2]]

    if len(tied) == 1:
        cmd = top[0]
        chosen = auto_yes  # with --yes we don't reconfirm below
    else:
        # Ambiguous — ask rather than guess. The choice itself is confirmation.
        cmd = ask_choice(candidates)
        if cmd is None:
            print("Aborted.")
            return 0
        chosen = True

    setup_cmds = collect_setup(blocks) if do_setup else []

    if not chosen:
        if not confirm(cmd, setup_cmds):
            print("Aborted.")
            return 0
    else:
        show_setup(setup_cmds)

    # Run setup steps first; stop if any of them fails.
    for s in setup_cmds:
        rc = run(s, workdir)
        if rc != 0:
            print(f"Setup step failed (exit {rc}); not launching.",
                  file=sys.stderr)
            return rc

    if background:
        return run_background(cmd, workdir)
    return run(cmd, workdir)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except (KeyboardInterrupt, EOFError):
        print("\nAborted.")
        sys.exit(130)
